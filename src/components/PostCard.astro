---
import CategoryPill from "./CategoryPill.astro";

interface Props {
  title: string;
  date: Date;
  category: "Technical" | "Essay" | "Project";
  excerpt: string;
  slug: string;
  last?: boolean;
  staggerIndex?: number;
}

const { title, date, category, excerpt, slug, last = false, staggerIndex = 0 } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<a
  href={`/blog/${slug}`}
  class="post-stagger post-card"
  style={`--stagger-index:${staggerIndex};${last ? 'border-bottom:none;' : ''}`}
>
  <div class="post-meta">
    <CategoryPill category={category} />
    <span class="text-label">{formattedDate}</span>
  </div>
  <h3 class="post-title">{title}</h3>
  <p class="post-excerpt">{excerpt}</p>
</a>

<style>
  .post-card {
    text-decoration: none;
    display: block;
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .post-title {
    font-size: var(--font-size-title);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 6px 0;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .post-card:hover .post-title {
    color: var(--color-accent);
  }

  .post-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 6px 0 0 0;
  }

  :global(.category-pill) {
    position: relative;
  }

  :global(.category-pill)::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1.5px solid currentColor;
    opacity: 0;
    pointer-events: none;
  }

  .post-card:hover :global(.category-pill)::after {
    animation: pillPing 2.4s var(--ease-out) forwards;
  }

  @keyframes pillPing {
    0% { transform: scale(1); opacity: 0.6; }
    14% { transform: scale(1.35); opacity: 0; }
    17% { transform: scale(1); opacity: 0; }

    33% { transform: scale(1); opacity: 0.4; }
    47% { transform: scale(1.25); opacity: 0; }
    50% { transform: scale(1); opacity: 0; }

    66% { transform: scale(1); opacity: 0.2; }
    79% { transform: scale(1.15); opacity: 0; }
    82% { transform: scale(1); opacity: 0; }

    100% { transform: scale(1); opacity: 0; }
  }
</style>
