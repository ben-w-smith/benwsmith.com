---
---

<div class="sandbox-wrapper">
  <div class="sandbox-header">
    <h2 class="sandbox-title">Badge Ping</h2>
    <p class="sandbox-desc">Category pill ping and throb ring animations.</p>
  </div>

  <div class="demo-area">
    <div class="pill-row">
      <span class="pill" data-color="technical" style="--pill-color:#007AFF;--pill-bg:#007AFF1A">
        Technical
        <span class="pill-ring"></span>
      </span>
      <span class="pill" data-color="essay" style="--pill-color:#FF6B6B;--pill-bg:#FF6B6B1A">
        Essay
        <span class="pill-ring"></span>
      </span>
      <span class="pill" data-color="project" style="--pill-color:#4ECDC4;--pill-bg:#4ECDC41A">
        Project
        <span class="pill-ring"></span>
      </span>
    </div>
    <div class="button-row">
      <button class="trigger-btn" id="trigger-all">Trigger Animation</button>
      <button class="trigger-btn" id="trigger-single">Trigger Single</button>
    </div>
  </div>

  <div class="sandbox-controls">
    <div class="control-group">
      <label for="slider-pingDuration">Ping Duration</label>
      <input type="range" id="slider-pingDuration" min="100" max="2000" value="500" step="50" />
      <span class="control-value" data-for="pingDuration">500ms</span>
    </div>

    <div class="control-group">
      <label for="slider-pingStartScale">Ping Start Scale</label>
      <input type="range" id="slider-pingStartScale" min="0.5" max="1.0" value="1.0" step="0.05" />
      <span class="control-value" data-for="pingStartScale">1.0</span>
    </div>

    <div class="control-group">
      <label for="slider-pingEndScale">Ping End Scale</label>
      <input type="range" id="slider-pingEndScale" min="1.1" max="2.5" value="1.4" step="0.1" />
      <span class="control-value" data-for="pingEndScale">1.4</span>
    </div>

    <div class="control-group">
      <label for="slider-pingStartOpacity">Ping Start Opacity</label>
      <input type="range" id="slider-pingStartOpacity" min="0.1" max="1.0" value="0.7" step="0.05" />
      <span class="control-value" data-for="pingStartOpacity">0.7</span>
    </div>

    <div class="control-group">
      <label for="select-pingEasing">Ping Easing</label>
      <select id="select-pingEasing">
        <option value="0.16,1,0.3,1" selected>ease-out</option>
        <option value="0.45,0,0.55,1">ease-in-out</option>
        <option value="0.34,1.56,0.64,1">ease-spring</option>
        <option value="linear">linear</option>
      </select>
      <span class="control-value" data-for="pingEasing">0.16,1,0.3,1</span>
    </div>

    <div class="control-group">
      <label for="slider-throbDuration">Throb Duration</label>
      <input type="range" id="slider-throbDuration" min="200" max="4000" value="1400" step="100" />
      <span class="control-value" data-for="throbDuration">1400ms</span>
    </div>

    <div class="control-group">
      <label for="slider-throbMinScale">Throb Min Scale</label>
      <input type="range" id="slider-throbMinScale" min="0.9" max="1.0" value="1.0" step="0.01" />
      <span class="control-value" data-for="throbMinScale">1.0</span>
    </div>

    <div class="control-group">
      <label for="slider-throbMaxScale">Throb Max Scale</label>
      <input type="range" id="slider-throbMaxScale" min="1.01" max="1.3" value="1.06" step="0.01" />
      <span class="control-value" data-for="throbMaxScale">1.06</span>
    </div>

    <div class="control-group">
      <label for="slider-throbMinOpacity">Throb Min Opacity</label>
      <input type="range" id="slider-throbMinOpacity" min="0.02" max="0.3" value="0.12" step="0.02" />
      <span class="control-value" data-for="throbMinOpacity">0.12</span>
    </div>

    <div class="control-group">
      <label for="slider-throbMaxOpacity">Throb Max Opacity</label>
      <input type="range" id="slider-throbMaxOpacity" min="0.05" max="0.5" value="0.22" step="0.02" />
      <span class="control-value" data-for="throbMaxOpacity">0.22</span>
    </div>

    <div class="control-group">
      <label for="select-throbEasing">Throb Easing</label>
      <select id="select-throbEasing">
        <option value="0.45,0,0.55,1" selected>ease-in-out</option>
        <option value="0.16,1,0.3,1">ease-out</option>
        <option value="0.34,1.56,0.64,1">ease-spring</option>
        <option value="linear">linear</option>
      </select>
      <span class="control-value" data-for="throbEasing">0.45,0,0.55,1</span>
    </div>

    <div class="control-group">
      <label for="checkbox-autoRepeat">Auto-repeat</label>
      <div style="display:flex;align-items:center;gap:8px;margin-top:2px">
        <input type="checkbox" id="checkbox-autoRepeat" />
        <span class="control-value" data-for="autoRepeat">off</span>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const allRings = document.querySelectorAll<HTMLSpanElement>(".sandbox-wrapper .pill-ring");
    const essayRing = document.querySelector<HTMLSpanElement>('.sandbox-wrapper .pill[data-color="essay"] .pill-ring');
    const triggerAllBtn = document.querySelector<HTMLButtonElement>("#trigger-all");
    const triggerSingleBtn = document.querySelector<HTMLButtonElement>("#trigger-single");

    if (!triggerAllBtn || !triggerSingleBtn || allRings.length === 0 || !essayRing) return;

    // Active animations per ring, for cleanup
    const activeAnimations = new Map<HTMLSpanElement, Animation[]>();
    let autoRepeatTimer: ReturnType<typeof setTimeout> | null = null;

    function getParam(id: string): number {
      const el = document.querySelector<HTMLInputElement>("#" + id);
      return el ? parseFloat(el.value) : 0;
    }

    function getEasing(selectId: string): string {
      const el = document.querySelector<HTMLSelectElement>("#" + selectId);
      if (!el) return "ease-out";
      const val = el.value;
      if (val === "linear") return "linear";
      return `cubic-bezier(${val})`;
    }

    function isAutoRepeat(): boolean {
      const el = document.querySelector<HTMLInputElement>("#checkbox-autoRepeat");
      return el ? el.checked : false;
    }

    function runSequence(rings: HTMLSpanElement[]) {
      for (const ring of rings) {
        // Cancel existing animations on this ring
        const existing = activeAnimations.get(ring);
        if (existing) {
          for (const anim of existing) anim.cancel();
          activeAnimations.delete(ring);
        }

        const pingDuration = getParam("slider-pingDuration");
        const pingStartScale = getParam("slider-pingStartScale");
        const pingEndScale = getParam("slider-pingEndScale");
        const pingStartOpacity = getParam("slider-pingStartOpacity");
        const pingEasing = getEasing("select-pingEasing");

        const throbDuration = getParam("slider-throbDuration");
        const throbMinScale = getParam("slider-throbMinScale");
        const throbMaxScale = getParam("slider-throbMaxScale");
        const throbMinOpacity = getParam("slider-throbMinOpacity");
        const throbMaxOpacity = getParam("slider-throbMaxOpacity");
        const throbEasing = getEasing("select-throbEasing");

        const ringAnimations: Animation[] = [];

        // Ping
        const ping = ring.animate(
          [
            { transform: `scale(${pingStartScale})`, opacity: pingStartOpacity },
            { transform: `scale(${pingEndScale})`, opacity: 0 },
          ],
          {
            duration: pingDuration,
            easing: pingEasing,
            fill: "forwards",
          }
        );
        ringAnimations.push(ping);

        // Throb (starts after ping finishes)
        const throb = ring.animate(
          [
            { transform: `scale(${throbMinScale})`, opacity: throbMinOpacity },
            { transform: `scale(${throbMaxScale})`, opacity: throbMaxOpacity },
            { transform: `scale(${throbMinScale})`, opacity: throbMinOpacity },
          ],
          {
            duration: throbDuration,
            delay: pingDuration,
            easing: throbEasing,
            iterations: 2,
          }
        );
        ringAnimations.push(throb);

        activeAnimations.set(ring, ringAnimations);
      }

      // Auto-repeat
      if (isAutoRepeat()) {
        const totalDuration =
          getParam("slider-pingDuration") +
          getParam("slider-throbDuration") * 2;
        autoRepeatTimer = setTimeout(() => {
          runSequence(rings);
        }, totalDuration + 200);
      }
    }

    triggerAllBtn.addEventListener("click", () => {
      if (autoRepeatTimer !== null) {
        clearTimeout(autoRepeatTimer);
        autoRepeatTimer = null;
      }
      const rings = Array.from(allRings);
      runSequence(rings);
    });

    triggerSingleBtn.addEventListener("click", () => {
      if (autoRepeatTimer !== null) {
        clearTimeout(autoRepeatTimer);
        autoRepeatTimer = null;
      }
      runSequence([essayRing]);
    });

    // Wire sliders to update display values
    const sliderIds = [
      "slider-pingDuration",
      "slider-pingStartScale",
      "slider-pingEndScale",
      "slider-pingStartOpacity",
      "slider-throbDuration",
      "slider-throbMinScale",
      "slider-throbMaxScale",
      "slider-throbMinOpacity",
      "slider-throbMaxOpacity",
    ];

    const unitSuffixes: Record<string, string> = {
      slider_pingDuration: "ms",
      slider_throbDuration: "ms",
    };

    for (const id of sliderIds) {
      const input = document.querySelector<HTMLInputElement>("#" + id);
      if (!input) continue;
      const dataKey = id.replace("slider-", "");
      const display = document.querySelector<HTMLElement>(
        '.control-value[data-for="' + dataKey + '"]'
      );
      const suffix = id in unitSuffixes ? unitSuffixes[id] : "";
      input.addEventListener("input", () => {
        if (display) display.textContent = input.value + suffix;
      });
    }

    // Wire easing selects
    const easingSelects = [
      { selectId: "select-pingEasing", dataFor: "pingEasing" },
      { selectId: "select-throbEasing", dataFor: "throbEasing" },
    ];

    for (const { selectId, dataFor } of easingSelects) {
      const sel = document.querySelector<HTMLSelectElement>("#" + selectId);
      if (!sel) continue;
      const display = document.querySelector<HTMLElement>(
        '.control-value[data-for="' + dataFor + '"]'
      );
      sel.addEventListener("change", () => {
        if (display) display.textContent = sel.value;
      });
    }

    // Wire auto-repeat checkbox
    const autoCheckbox = document.querySelector<HTMLInputElement>("#checkbox-autoRepeat");
    const autoDisplay = document.querySelector<HTMLElement>(
      '.control-value[data-for="autoRepeat"]'
    );
    if (autoCheckbox && autoDisplay) {
      autoCheckbox.addEventListener("change", () => {
        autoDisplay.textContent = autoCheckbox.checked ? "on" : "off";
        if (!autoCheckbox.checked && autoRepeatTimer !== null) {
          clearTimeout(autoRepeatTimer);
          autoRepeatTimer = null;
        }
      });
    }

    document.addEventListener("astro:before-swap", () => {
      // Cancel all running animations
      for (const [, anims] of activeAnimations) {
        for (const anim of anims) anim.cancel();
      }
      activeAnimations.clear();
      if (autoRepeatTimer !== null) {
        clearTimeout(autoRepeatTimer);
        autoRepeatTimer = null;
      }
    });
  });
</script>

<style>
  .sandbox-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .sandbox-header {
    margin-bottom: var(--spacing-xs);
  }

  .sandbox-title {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-xs);
  }

  .sandbox-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  .demo-area {
    padding: var(--spacing-xl, 32px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg, 24px);
    min-height: 120px;
    justify-content: center;
  }

  .pill-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .pill {
    position: relative;
    display: inline-block;
    font-size: var(--font-size-label, 12px);
    font-weight: var(--font-weight-medium, 500);
    padding: 4px 12px;
    border-radius: var(--radius-sm, 6px);
    color: var(--pill-color);
    background: var(--pill-bg);
  }

  .pill-ring {
    position: absolute;
    inset: -3px;
    border: 1.5px solid currentColor;
    border-radius: inherit;
    opacity: 0;
    pointer-events: none;
  }

  .button-row {
    display: flex;
    gap: 8px;
  }

  .trigger-btn {
    padding: 6px 16px;
    font-size: 13px;
    font-weight: var(--font-weight-medium, 500);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-bg-off);
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .trigger-btn:hover {
    background: var(--color-border);
  }

  .sandbox-controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md) var(--spacing-xl);
    padding-top: var(--spacing-md);
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .control-group label {
    font-size: 13px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  .control-group input[type="range"] {
    width: 100%;
    accent-color: var(--color-accent, #007aff);
  }

  .control-group select {
    width: 100%;
    padding: 4px 8px;
    font-size: 13px;
    font-family: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-bg-off);
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .control-group select:focus {
    outline: 2px solid var(--color-accent, #007aff);
    outline-offset: 1px;
  }

  .control-group input[type="checkbox"] {
    accent-color: var(--color-accent, #007aff);
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  .control-value {
    font-size: 12px;
    font-family: var(--font-family-mono, monospace);
    color: var(--color-text-tertiary, #999);
  }

  @media (max-width: 600px) {
    .sandbox-controls {
      grid-template-columns: 1fr;
    }
  }
</style>
