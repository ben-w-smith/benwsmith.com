---
---

<div class="sandbox-wrapper">
  <div class="sandbox-header">
    <h2 class="sandbox-title">Link Hover</h2>
    <p class="sandbox-desc">Center-out expanding underline with text color transition</p>
  </div>

  <div class="demo-area" id="link-demo-area">
    <a class="demo-link demo-nav-link" href="#">Home</a>
    <a class="demo-link demo-footer-link" href="#">
      GitHub
      <svg class="external-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 3L3 9M9 3H5M9 3V7" />
      </svg>
    </a>
    <a class="demo-link demo-back-link" href="#">&larr; Back to blog</a>
  </div>

  <div class="sandbox-controls">
    <div class="control-group">
      <label for="slider-underlineDuration">Underline Duration</label>
      <input type="range" id="slider-underlineDuration" min="50" max="1000" value="200" step="25" />
      <span class="control-value" data-for="underlineDuration">200ms</span>
    </div>

    <div class="control-group">
      <label for="select-underlineEasing">Underline Easing</label>
      <select id="select-underlineEasing">
        <option value="cubic-bezier(0.16, 1, 0.3, 1)">ease-out</option>
        <option value="cubic-bezier(0.45, 0, 0.55, 1)">ease-in-out</option>
        <option value="cubic-bezier(0.34, 1.56, 0.64, 1)">ease-spring</option>
        <option value="linear">linear</option>
      </select>
      <span class="control-value" data-for="underlineEasing">ease-out</span>
    </div>

    <div class="control-group">
      <label for="slider-underlineHeight">Underline Height</label>
      <input type="range" id="slider-underlineHeight" min="0.5" max="4" value="1.5" step="0.5" />
      <span class="control-value" data-for="underlineHeight">1.5px</span>
    </div>

    <div class="control-group">
      <label for="select-underlineColor">Underline Color</label>
      <select id="select-underlineColor">
        <option value="var(--color-accent)">Accent</option>
        <option value="var(--color-text-secondary)">Secondary</option>
        <option value="var(--color-text-primary)">Primary</option>
      </select>
      <span class="control-value" data-for="underlineColor">Accent</span>
    </div>

    <div class="control-group">
      <label for="slider-underlineOffset">Underline Offset</label>
      <input type="range" id="slider-underlineOffset" min="-6" max="0" value="-2" step="1" />
      <span class="control-value" data-for="underlineOffset">-2px</span>
    </div>

    <div class="control-group">
      <label for="slider-textColorDuration">Text Color Duration</label>
      <input type="range" id="slider-textColorDuration" min="50" max="1000" value="200" step="25" />
      <span class="control-value" data-for="textColorDuration">200ms</span>
    </div>

    <div class="control-group">
      <label for="slider-iconFadeDuration">Icon Fade Duration</label>
      <input type="range" id="slider-iconFadeDuration" min="50" max="800" value="200" step="25" />
      <span class="control-value" data-for="iconFadeDuration">200ms</span>
    </div>

    <div class="control-group">
      <label for="slider-iconSlideDistance">Icon Slide Distance</label>
      <input type="range" id="slider-iconSlideDistance" min="0" max="6" value="1" step="1" />
      <span class="control-value" data-for="iconSlideDistance">1px</span>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const demoArea = document.getElementById("link-demo-area");
    if (!demoArea) return;

    // Prevent demo links from navigating
    const links = demoArea.querySelectorAll<HTMLAnchorElement>(".demo-link");
    for (const link of links) {
      link.addEventListener("click", (e) => e.preventDefault());
    }

    // --- Range sliders ---
    type RangeConfig = {
      id: string;
      prop: string;
      suffix: string;
    };

    const rangeControls: RangeConfig[] = [
      { id: "underlineDuration", prop: "--demo-underline-duration", suffix: "ms" },
      { id: "underlineHeight", prop: "--demo-underline-height", suffix: "px" },
      { id: "underlineOffset", prop: "--demo-underline-offset", suffix: "px" },
      { id: "textColorDuration", prop: "--demo-text-color-duration", suffix: "ms" },
      { id: "iconFadeDuration", prop: "--demo-icon-fade-duration", suffix: "ms" },
      { id: "iconSlideDistance", prop: "--demo-icon-slide-distance", suffix: "px" },
    ];

    for (const ctrl of rangeControls) {
      const input = document.querySelector<HTMLInputElement>("#slider-" + ctrl.id);
      const display = document.querySelector<HTMLElement>('.control-value[data-for="' + ctrl.id + '"]');
      if (!input) continue;

      input.addEventListener("input", () => {
        demoArea.style.setProperty(ctrl.prop, input.value + ctrl.suffix);
        if (display) display.textContent = input.value + ctrl.suffix;
      });
    }

    // --- Select dropdowns ---
    const easingSelect = document.querySelector<HTMLSelectElement>("#select-underlineEasing");
    const easingDisplay = document.querySelector<HTMLElement>('.control-value[data-for="underlineEasing"]');
    if (easingSelect) {
      easingSelect.addEventListener("change", () => {
        demoArea.style.setProperty("--demo-underline-easing", easingSelect.value);
        if (easingDisplay) easingDisplay.textContent = easingSelect.options[easingSelect.selectedIndex].text;
      });
    }

    const colorSelect = document.querySelector<HTMLSelectElement>("#select-underlineColor");
    const colorDisplay = document.querySelector<HTMLElement>('.control-value[data-for="underlineColor"]');
    if (colorSelect) {
      colorSelect.addEventListener("change", () => {
        demoArea.style.setProperty("--demo-underline-color", colorSelect.value);
        if (colorDisplay) colorDisplay.textContent = colorSelect.options[colorSelect.selectedIndex].text;
      });
    }

    document.addEventListener("astro:before-swap", () => {
      // Cleanup: nothing persistent to tear down
    });
  });
</script>

<style>
  .sandbox-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .sandbox-header {
    margin-bottom: var(--spacing-xs);
  }

  .sandbox-title {
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-xs);
  }

  .sandbox-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  /* --- Demo area --- */
  .demo-area {
    padding: var(--spacing-xl, 32px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    display: flex;
    gap: var(--spacing-xl, 32px);
    align-items: center;
    min-height: 80px;
  }

  /* --- Shared link styles --- */
  .demo-link {
    position: relative;
    text-decoration: none;
    cursor: pointer;
    font-size: 13px;
    transition: color var(--demo-text-color-duration, 200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .demo-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: var(--demo-underline-offset, -2px);
    width: 0;
    height: var(--demo-underline-height, 1.5px);
    background: var(--demo-underline-color, var(--color-accent));
    transition:
      width var(--demo-underline-duration, 200ms) var(--demo-underline-easing, cubic-bezier(0.16, 1, 0.3, 1)),
      left var(--demo-underline-duration, 200ms) var(--demo-underline-easing, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .demo-link:hover::after {
    width: 100%;
    left: 0;
  }

  /* --- Nav link variant --- */
  .demo-nav-link {
    color: var(--color-text-secondary);
  }

  .demo-nav-link:hover {
    color: var(--color-text-primary);
  }

  .demo-nav-link::after {
    height: var(--demo-underline-height, 1.5px);
    background: var(--demo-underline-color, var(--color-accent));
  }

  /* --- Footer link variant (with icon) --- */
  .demo-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--color-text-secondary);
  }

  .demo-footer-link:hover {
    color: var(--color-text-primary);
  }

  .demo-footer-link::after {
    height: 1px;
  }

  .external-icon {
    opacity: 0;
    transform: translateY(var(--demo-icon-slide-distance, 1px));
    transition:
      opacity var(--demo-icon-fade-duration, 200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)),
      transform var(--demo-icon-fade-duration, 200ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .demo-footer-link:hover .external-icon {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- Back link variant --- */
  .demo-back-link {
    color: var(--color-accent);
  }

  .demo-back-link::after {
    height: 1px;
    background: var(--demo-underline-color, var(--color-accent));
  }

  .demo-back-link:hover {
    color: var(--color-text-primary);
  }

  /* --- Controls --- */
  .sandbox-controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md) var(--spacing-xl);
    padding-top: var(--spacing-md);
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .control-group label {
    font-size: 13px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  .control-group input[type="range"] {
    width: 100%;
    accent-color: var(--color-accent, #007aff);
  }

  .control-group select {
    width: 100%;
    font-size: 13px;
    padding: 4px 6px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg-primary, #fff);
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .control-group select:focus {
    outline: 2px solid var(--color-accent, #007aff);
    outline-offset: 1px;
  }

  .control-value {
    font-size: 12px;
    font-family: var(--font-family-mono, monospace);
    color: var(--color-text-tertiary, #999);
  }

  @media (max-width: 600px) {
    .sandbox-controls {
      grid-template-columns: 1fr;
    }

    .demo-area {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-lg, 24px);
    }
  }
</style>
