---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggleSandbox from "../components/lab/ThemeToggleSandbox.astro";
import PostCardSandbox from "../components/lab/PostCardSandbox.astro";
import BadgePingSandbox from "../components/lab/BadgePingSandbox.astro";
import GolSandbox from "../components/lab/GolSandbox.astro";
import LinkHoverSandbox from "../components/lab/LinkHoverSandbox.astro";
---
<BaseLayout title="Lab">
  <section style="padding:var(--spacing-2xl) 0">
    <h1 style="font-size:var(--font-size-site-name);font-weight:var(--font-weight-bold);line-height:1.1;margin-bottom:var(--spacing-sm)">Lab</h1>
    <p style="font-size:15px;color:var(--color-text-secondary);letter-spacing:0.02em">Animation sandbox. Local only.</p>
  </section>

  <section style="margin-bottom:var(--spacing-2xl)">
    <ThemeToggleSandbox />
  </section>

  <hr style="border:none;border-top:1px solid var(--color-border);margin:var(--spacing-2xl) 0;" />

  <section style="margin-bottom:var(--spacing-2xl)">
    <PostCardSandbox />
  </section>

  <hr style="border:none;border-top:1px solid var(--color-border);margin:var(--spacing-2xl) 0;" />

  <section style="margin-bottom:var(--spacing-2xl)">
    <BadgePingSandbox />
  </section>

  <hr style="border:none;border-top:1px solid var(--color-border);margin:var(--spacing-2xl) 0;" />

  <section style="margin-bottom:var(--spacing-2xl)">
    <GolSandbox />
  </section>

  <hr style="border:none;border-top:1px solid var(--color-border);margin:var(--spacing-2xl) 0;" />

  <section style="margin-bottom:var(--spacing-2xl)">
    <LinkHoverSandbox />
  </section>
</BaseLayout>
