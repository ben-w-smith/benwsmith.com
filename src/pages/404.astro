---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <section style="padding:var(--spacing-2xl) 0;text-align:center;min-height:50vh;display:flex;flex-direction:column;justify-content:center;" data-reveal>
    <h1 style="font-size:var(--font-size-site-name);font-weight:var(--font-weight-bold);color:var(--color-text-primary);line-height:1.1;margin-bottom:var(--spacing-md);">404</h1>
    <p style="font-size:var(--font-size-body);color:var(--color-text-secondary);margin-bottom:var(--spacing-xl);">This page doesn't exist — or it wandered off somewhere.</p>
    <a href="/" style="font-size:var(--font-size-label);font-weight:var(--font-weight-medium);color:var(--color-accent);text-decoration:none;">← Back to Blog</a>
  </section>
</BaseLayout>
